{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug main.py (with queue monitor)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "env": {
                "DEBUG": "1",
                "DEBUG_INTERVAL": "1.0",
                "PYTHONUNBUFFERED": "1"
            }
        },
        {
            "name": "Debug main.py (clean run)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "env": {
                "PYTHONUNBUFFERED": "1"
            }
        },
        {
            "name": "Debug scanner.py only",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scanner.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "env": {
                "PYTHONUNBUFFERED": "1"
            }
        },
        {
            "name": "Python: Attach to running process",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "justMyCode": false
        }
    ]
}
